- sentiment_label, sentiment_class = sentiment_badge(message.ai_sentiment_score)
- counts = reaction_counts_for(message)

.card.shadow-sm{id: dom_id(message)}
  .card-body
    .d-flex.justify-content-between.align-items-start.gap-2
      .d-flex.flex-column
        %strong= message.user.username
        %small.text-secondary= l(message.created_at, format: :short)
      %span.badge{class: sentiment_class}= sentiment_label

    .mt-3= simple_format(message.content)

    .d-flex.align-items-center.flex-wrap.gap-2.mt-3{data: {controller: "reaction", reaction_message_id_value: message.id}}
      - Reaction::REACTION_TYPES.each do |reaction_type|
        %button.btn.btn-sm.btn-outline-secondary{type: "button", data: {action: "reaction#react", reaction_type: reaction_type}}
          = reaction_type
          %span.badge.text-bg-light.ms-1{data: {count_for: reaction_type}}= counts[reaction_type]
      %small.text-secondary{data: {reaction_target: "feedback"}}

    .mt-3
      %small.text-secondary
        = "#{message.replies.size} comentário(s)"
        = " • "
        = link_to "Abrir thread", message_path(message), class: "link-secondary"
